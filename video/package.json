{
  "name": "nails-agent-video-demo",
  "version": "1.0.0",
  "description": "Remotion video demo for nails-agent-platform try-on flow",
  "scripts": {
    "start": "remotion studio",
    "build": "remotion render NailsTryOnDemo out/demo.mp4 --codec=h264",
    "render:gif": "remotion render NailsTryOnDemo out/demo.gif --codec=gif",
    "snapshot": "remotion still NailsTryOnDemo out/snapshot.png --frame=0"
  },
  "dependencies": {
    "@remotion/cli": "4.0.460",
    "remotion": "4.0.460",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.4.0"
  },
  "remotion": {
    "entryPoint": "src/index.ts"
  }
}
