# Local-dev reverse proxy for the nails-agent-platform.
#
#   /         → Chat UI      :8501  (web/chat_app.py)
#   /user/*   → C端 AI试戴  :8503  (consumer/app.py)
#   /api/*    → FastAPI      :8000  (strip prefix before forwarding)

localhost:8080 {
    log {
        output stdout
        format console
    }

    # FastAPI under /api/* — strip the prefix before forwarding.
    handle_path /api/* {
        reverse_proxy localhost:8000
    }

    # C端 AI试戴 under /user/* — Streamlit needs WebSocket (HTTP/1.1).
    handle_path /user/* {
        reverse_proxy localhost:8503 {
            transport http {
                versions 1.1
            }
        }
    }

    # Default: Chat UI
    handle {
        reverse_proxy localhost:8501 {
            transport http {
                versions 1.1
            }
        }
    }
}
