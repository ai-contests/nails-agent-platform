# ── LLM providers ────────────────────────────────────────────────────────────
# Tag extraction uses OpenAI-compatible DashScope by default.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
NAILS_TAG_LLM_API_KEY=
NAILS_TAG_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
NAILS_TAG_LLM_MODEL=qwen3-max

# Vision tag extraction (Qwen-VL). Defaults to qwen-vl-max with the same DashScope key.
# Override to use a different model/endpoint.
# NAILS_VISION_TAG_MODEL=qwen-vl-max
# NAILS_VISION_TAG_API_KEY=
# NAILS_VISION_TAG_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Agent mode provider choices. Leave keys empty to run the rule-based pipeline.
MODELSCOPE_API_KEY=
NAILS_MODELSCOPE_BASE_URL=https://api-inference.modelscope.cn/v1
MODELSCOPE_BASE_URL=https://api-inference.modelscope.cn/v1
NAILS_MODELSCOPE_MODEL=Qwen/Qwen3-235B-A22B-Instruct-2507

OPENROUTER_API_KEY=
NAILS_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
NAILS_OPENROUTER_MODEL=anthropic/claude-sonnet-4-5
NAILS_OPENROUTER_REFERER=https://github.com/ai-contests/nails-agent-platform

ANTHROPIC_API_KEY=
NAILS_AGENT_MODEL=claude-sonnet-4-5
NAILS_ANTHROPIC_MODEL=claude-sonnet-4-5
NAILS_REVIEWER_LLM_MODEL=claude-haiku-4-5-20251001
NAILS_HERMES_MODEL=anthropic/claude-sonnet-4-5

# Optional runtime DB override. Useful for tests or isolated local demos.
# NAILS_MEMORY_DB_PATH=/tmp/nails_agent_memory.db

# ── Roboflow (nail region extraction / instance segmentation) ───────────────
ROBOFLOW_API_KEY=

# ── ComfyUI Cloud (nail try-on image generation) ────────────────────────────
COMFYUI_API_KEY=your_api_key_here
# Default: bypass system HTTP(S)_PROXY for ComfyUI uploads.
# Set to 1 only if your network requires a proxy for cloud.comfy.org.
COMFYUI_USE_SYSTEM_PROXY=0

# ── XHS / Douyin / Instagram CDP (browser automation) ───────────────────────
# Launch Chrome with: open -a "Google Chrome" --args --remote-debugging-port=9222
# Then log in to xiaohongshu.com and douyin.com in that Chrome
CHROME_CDP_URL=http://localhost:9222

# XHS Skills directory (auto-detected if installed via hermes)
# XHS_SKILLS_DIR=~/.hermes/skills/xiaohongshu-skills

# ── Instagram (optional, for instaloader session-based scraping) ─────────────
# INSTAGRAM_SESSION_FILE=~/.config/instaloader/session-yourusername

# ── TikHub API (optional paid source — all free sources work without this) ───
TIKHUB_API_KEY=

# ── Telegram Bot (optional) ─────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=your_token_here
